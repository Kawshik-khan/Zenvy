// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  uniqueId      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password            String?
  role                String    @default("USER")
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  profile             Profile?
  messages      Message[]
  conversationParticipants ConversationParticipant[]
  conversationMessages     ConversationMessage[]
  
  // New Relations for UI Logic
  administeredGroups StudyGroup[]    @relation("GroupAdmin")
  groupMemberships   GroupMember[]
  sentGroupInvites    GroupInvite[]   @relation("GroupInviteInviter")
  receivedGroupInvites GroupInvite[]  @relation("GroupInviteInvitee")
  createdGroupResources GroupResource[] @relation("GroupResourceCreator")
  createdEvents      Event[]         @relation("EventCreator")
  eventRSVPs         EventAttendee[]
  groupMessages      GroupMessage[]
  notifications      Notification[]  @relation("UserNotifications")
  blocks             UserBlock[]     @relation("UserBlocking")
  blockedBy          UserBlock[]     @relation("UserBlocked")
  reports            Report[]        @relation("UserReporting")
  reportedBy         Report[]        @relation("UserReported")
  createdChannels    Channel[]        @relation("ChannelCreator")
  channelMemberships ChannelMember[]
  channelMessages    ChannelMessage[]
  pushSubscriptions  PushSubscription[]
  callParticipations CallParticipant[]
  pomodoroSessions   PomodoroSession[]
  studyAds           StudyAd[]
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college           String?
  major             String?
  semester          Int?
  bio               String?
  studyStyle        String?
  interests         String? // Stored as comma-separated or JSON
  profileImage      String?
  availability      String? // Weekly schedule
  matchingAvailable Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  matches           Match[]  @relation("MatchedProfiles")
  inverseMatches    Match[]  @relation("InverseMatchedProfiles")
}

model Match {
  id               String    @id @default(cuid())
  profileId        String
  profile          Profile   @relation("MatchedProfiles", fields: [profileId], references: [id])
  matchedProfileId String
  matchedProfile   Profile   @relation("InverseMatchedProfiles", fields: [matchedProfileId], references: [id])
  status           String    @default("PENDING")
  compatibility    Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  chatRoom         ChatRoom?

  @@unique([profileId, matchedProfileId])
}

model StudyAd {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  description  String
  subjects     String
  availability String
  mode         String   @default("ANY") // ONLINE, IN_PERSON, HYBRID, ANY
  status       String   @default("ACTIVE") // ACTIVE, PAUSED, CLOSED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}

model ChatRoom {
  id        String    @id @default(cuid())
  matchId   String    @unique
  match     Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id         String   @id @default(cuid())
  content    String
  fileUrl    String?
  fileType   String?
  fileName   String?
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  chatRoomId String?
  chatRoom   ChatRoom? @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  roomId     String   @default("global")
  createdAt  DateTime @default(now())
}

// ============================================
// NEW MODELS FOR UI LOGIC & SUPABASE MIGRATION
// ============================================

model StudyGroup {
  id          String         @id @default(cuid())
  name        String
  description String?
  subject     String?
  avatar      String?
  adminId     String
  admin       User           @relation("GroupAdmin", fields: [adminId], references: [id])
  members     GroupMember[]
  invites     GroupInvite[]
  resources   GroupResource[]
  messages    GroupMessage[]
  events      Event[]
  createdAt   DateTime       @default(now())
}

model GroupMember {
  id        String     @id @default(cuid())
  groupId   String
  userId    String
  role      String     @default("MEMBER") // ADMIN, MEMBER
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime   @default(now())
  
  @@unique([groupId, userId])
}

model Conversation {
  id            String                    @id @default(cuid())
  type          String
  title         String?
  avatar        String?
  groupId       String?
  channelId     String?
  dmKey         String?                   @unique
  lastMessageId String?
  lastMessageAt DateTime?
  participants  ConversationParticipant[]
  messages      ConversationMessage[]
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([lastMessageAt])
  @@index([groupId])
  @@index([channelId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  role           String       @default("MEMBER")
  lastReadAt     DateTime?
  muted          Boolean      @default(false)
  archived       Boolean      @default(false)
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, conversationId])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  fileUrl        String?
  fileType       String?
  fileName       String?
  status         String       @default("SENT")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model GroupInvite {
  id        String     @id @default(cuid())
  groupId   String
  inviterId String
  inviteeId String
  status    String     @default("PENDING") // PENDING, ACCEPTED, DECLINED, CANCELED
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter   User       @relation("GroupInviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee   User       @relation("GroupInviteInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model GroupResource {
  id           String     @id @default(cuid())
  groupId      String
  creatorId    String
  title        String
  description  String?
  resourceType String     @default("LINK") // LINK, FILE, NOTE
  url          String?
  fileName     String?
  fileType     String?
  pinned       Boolean    @default(false)
  group        StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator      User       @relation("GroupResourceCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Event {
  id          String          @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  type        String          @default("VIRTUAL")
  creatorId   String
  creator     User            @relation("EventCreator", fields: [creatorId], references: [id])
  groupId     String?
  group       StudyGroup?     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attendees   EventAttendee[]
  createdAt   DateTime        @default(now())
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    String   @default("GOING") // GOING, MAYBE, DECLINED
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([eventId, userId])
}

model GroupMessage {
  id        String     @id @default(cuid())
  content   String
  fileUrl   String?
  fileType  String?
  fileName  String?
  senderId  String
  groupId   String
  sender    User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String   // MATCH_REQUEST, GROUP_INVITE, SYSTEM
  content   String
  read      Boolean  @default(false)
  relatedId String?  // ID of the group/match
  createdAt DateTime @default(now())
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("UserBlocking", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("UserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([blockerId, blockedId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation("UserReporting", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedId String
  reported   User     @relation("UserReported", fields: [reportedId], references: [id], onDelete: Cascade)
  reason     String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
}

// ============================================
// CHANNELS FEATURE
// ============================================

model Channel {
  id          String           @id @default(cuid())
  name        String
  tag         String           @unique
  description String?
  avatar      String?
  creatorId   String
  creator     User             @relation("ChannelCreator", fields: [creatorId], references: [id])
  members     ChannelMember[]
  messages    ChannelMessage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  role      String   @default("MEMBER")
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([channelId, userId])
}

model ChannelMessage {
  id        String   @id @default(cuid())
  content   String
  fileUrl   String?
  fileType  String?
  fileName  String?
  senderId  String
  channelId String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ============================================
// PUSH NOTIFICATIONS
// ============================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// ============================================
// FOCUS / POMODORO
// ============================================

model PomodoroSession {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode             String   @default("FOCUS") // FOCUS, SHORT_BREAK, LONG_BREAK
  plannedMinutes   Int
  completedMinutes Int
  startedAt        DateTime
  endedAt          DateTime
  status           String   @default("COMPLETED") // COMPLETED, SKIPPED, CANCELED
  trackId          String?
  createdAt        DateTime @default(now())

  @@index([userId, endedAt])
  @@index([status])
}

// ============================================
// WEBRTC CALLING FEATURE
// ============================================

model CallSession {
  id             String            @id @default(cuid())
  roomId         String            @unique // dm:{conversationId}, group:{groupId}, channel:{channelId}, or lobby
  type           String            @default("GROUP") // DM, GROUP, CHANNEL, LOBBY
  mediaType      String            @default("AUDIO") // AUDIO, VIDEO
  status         String            @default("ACTIVE") // RINGING, ACTIVE, ENDED, MISSED
  conversationId String?
  groupId        String?
  channelId      String?
  startedById    String?
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  participants   CallParticipant[]

  @@index([conversationId])
  @@index([groupId])
  @@index([channelId])
  @@index([status])
}

model CallParticipant {
  id            String      @id @default(cuid())
  callId        String
  call          CallSession @relation(fields: [callId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          String      @default("MEMBER") // HOST, MEMBER
  status        String      @default("JOINED") // INVITED, JOINED, LEFT, DECLINED, MISSED
  audioEnabled  Boolean     @default(true)
  videoEnabled  Boolean     @default(false)
  screenSharing Boolean     @default(false)
  joinedAt      DateTime    @default(now())
  leftAt        DateTime?
  lastSeenAt    DateTime?
  
  @@unique([callId, userId])
  @@index([userId, status])
}
