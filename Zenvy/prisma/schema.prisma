// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  uniqueId      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       Profile?
  messages      Message[]
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college           String?
  major             String?
  semester          Int?
  bio               String?
  studyStyle        String?
  interests         String? // Stored as comma-separated or JSON
  profileImage      String?
  availability      String? // Weekly schedule
  matchingAvailable Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  matches           Match[]  @relation("MatchedProfiles")
  inverseMatches    Match[]  @relation("InverseMatchedProfiles")
}

model Match {
  id               String    @id @default(cuid())
  profileId        String
  profile          Profile   @relation("MatchedProfiles", fields: [profileId], references: [id])
  matchedProfileId String
  matchedProfile   Profile   @relation("InverseMatchedProfiles", fields: [matchedProfileId], references: [id])
  status           String    @default("PENDING")
  compatibility    Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  chatRoom         ChatRoom?

  @@unique([profileId, matchedProfileId])
}

model ChatRoom {
  id        String    @id @default(cuid())
  matchId   String    @unique
  match     Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}
